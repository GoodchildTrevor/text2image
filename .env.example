# =============================================================================
# imgen — environment configuration example
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Local model (HuggingFace model ID loaded by the diffusion pipeline)
# This value is also used as the fallback entry in LOCAL_MODELS.
# -----------------------------------------------------------------------------
LOCAL_MODEL=black-forest-labs/FLUX.1-schnell

# Short names that route to the local pipeline (comma-separated).
# These are the names clients send in the "model" field of requests.
# Defaults to the value of LOCAL_MODEL above if not set.
LOCAL_MODELS=flux-schnell

# -----------------------------------------------------------------------------
# Cloud provider (any OpenAI-compatible API)
# -----------------------------------------------------------------------------
# Bearer token for the cloud provider. Leave empty to disable cloud models.
API_KEY=

# Base URL of the OpenAI-compatible endpoint (no trailing slash).
# Example: https://api.openai.com/v1  or  https://your-proxy.example.com/api/v1
CLOUD_API_BASE_URL=

# Comma-separated list of cloud model IDs to route through the cloud provider.
# Example: gpt-image-1,google/gemini-2.0-flash-image-preview
CLOUD_MODELS=

# -----------------------------------------------------------------------------
# Inference defaults (local pipeline only)
# -----------------------------------------------------------------------------
FLUX_DEFAULT_STEPS=4
FLUX_DEFAULT_GUIDANCE=1.0

# -----------------------------------------------------------------------------
# Request validation
# -----------------------------------------------------------------------------
# Comma-separated list of allowed output sizes (WxH).
# Clients that send a size not in this list receive HTTP 400.
VALID_SIZES=1024x1024,864x1184,1184x864,768x1344,1344x768

# -----------------------------------------------------------------------------
# Startup behaviour
# -----------------------------------------------------------------------------
# Set to "true" to preload the local pipeline when the container starts.
# Speeds up the first request but increases startup time and memory usage.
PRELOAD_MODEL=false
