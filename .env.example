# ── Local diffusion pipeline ─────────────────────────────────────────────────
# Full HuggingFace model ID used to load the pipeline
LOCAL_MODEL=black-forest-labs/FLUX.1-schnell

# Short names that route to the local pipeline (comma-separated)
# Defaults to LOCAL_MODEL if not set
LOCAL_MODELS=flux-schnell

# Set to "1" to preload the pipeline at startup instead of on first request
PRELOAD_MODEL=0

# Default inference parameters for the local pipeline
FLUX_DEFAULT_STEPS=4
FLUX_DEFAULT_GUIDANCE=1.0


# ── OpenAI-compatible cloud provider ─────────────────────────────────────────
# Bearer token for any OpenAI-compat /chat/completions endpoint
API_KEY=

# Base URL of the OpenAI-compat endpoint (no trailing slash)
CLOUD_API_BASE_URL=https://api.example.com/v1

# Comma-separated model IDs routed to the above endpoint
CLOUD_MODELS=google/gemini-3.1-flash-image-preview,openai/gpt-5-image


# ── OpenRouter-compatible provider ────────────────────────────────────────────
# Bearer token
OPENROUTER_API_KEY=

# Base URL — REQUIRED when OPENROUTER_MODELS is set. No default, no hardcoded URL.
# Example: https://routerai.ru  or  https://openrouter.ai
OPENROUTER_BASE_URL=

# Optional fallback URL (used automatically if primary returns 4xx/5xx)
# OPENROUTER_FALLBACK_URL=
# OPENROUTER_FALLBACK_KEY=   # leave empty to reuse OPENROUTER_API_KEY

# Comma-separated model slugs routed to OPENROUTER_BASE_URL
OPENROUTER_MODELS=recraft/recraft-v4,bytedance-seed/seedream-4.5


# ── Valid output sizes ────────────────────────────────────────────────────────
VALID_SIZES=256x256,512x512,1024x1024,1792x1024,1024x1792


# ── Public URL for serving generated images ───────────────────────────────────
IMGEN_PUBLIC_URL=http://imgen:8010
